# Painel de admin (funções serverless /api). Configure no Vercel
# (Project Settings → Environment Variables) e, para rodar localmente,
# copie para `.env.local` e use `vercel dev`.

# Senha única de acesso ao /admin.
ADMIN_PASSWORD=troque-esta-senha

# Segredo para assinar o cookie de sessão (HMAC). Gere algo aleatório, ex:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Token GitHub fine-grained NESTE repo. Permissões necessárias:
#   - Contents: Read and write  (commitar overrides.json e companies.json)
#   - Actions:  Read and write  (disparar o workflow de sync manual)
GITHUB_TOKEN=
GITHUB_REPO=vitorsj/Astella-Jobs-Page
GITHUB_BRANCH=main

# IMPORTANTE (Fase 3 - sync manual): cadastre também APIFY_TOKEN como
# *secret do GitHub Actions* (repo → Settings → Secrets → Actions), pois o
# workflow .github/workflows/sync.yml roda o jobs_sync.py com ele.
