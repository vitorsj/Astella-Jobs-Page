# Painel de admin (funções serverless /api). Configure no Vercel
# (Project Settings → Environment Variables) e, para rodar localmente,
# copie para `.env.local` e use `vercel dev`.

# Senha única de acesso ao /admin.
ADMIN_PASSWORD=troque-esta-senha

# Segredo para assinar o cookie de sessão (HMAC). Gere algo aleatório, ex:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Token GitHub fine-grained NESTE repo, com permissão:
#   - Contents: Read and write  (commitar overrides.json ao salvar edições)
GITHUB_TOKEN=
GITHUB_REPO=vitorsj/Astella-Jobs-Page
GITHUB_BRANCH=main
